<script>
(function(){
  var hBtn = document.getElementById('hamburgerBtn');
  var mMenu = document.getElementById('mobileMenu');
  if(hBtn) hBtn.addEventListener('click', function(e){ e.stopPropagation(); mMenu.classList.toggle('open'); });
  document.addEventListener('click', function(e){ if(mMenu && !mMenu.contains(e.target) && e.target !== hBtn) mMenu.classList.remove('open'); });

  /* Animate score bars on scroll */
  var targets = [{id:'sb1',w:94},{id:'sb2',w:88},{id:'sb3',w:91},{id:'sb4',w:92},{id:'sb5',w:86}];
  var done = false;
  function tryAnimate(){
    if(done) return;
    var el = document.getElementById('sb1');
    if(!el) return;
    var r = el.closest('.method-right');
    if(r && r.getBoundingClientRect().top < window.innerHeight - 80){
      done = true;
      targets.forEach(function(t){ var b = document.getElementById(t.id); if(b) b.style.width = t.w+'%'; });
    }
  }
  window.addEventListener('scroll', tryAnimate, {passive:true});
  setTimeout(tryAnimate, 300);
})();

function openVisitModal(){
  document.getElementById('visit-modal').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}
function closeVisitModal(){
  document.getElementById('visit-modal').style.display = 'none';
  document.body.style.overflow = '';
}
function submitVisitModal(){
  var n = document.getElementById('vm-name').value.trim();
  var e = document.getElementById('vm-email').value.trim();
  if(!n || !e || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)){ alert('Por favor ingresa tu nombre y un correo válido.'); return; }
  document.getElementById('vm-submit').style.display = 'none';
  document.getElementById('vm-success').style.display = 'block';
}
document.getElementById('visit-modal').addEventListener('click', function(e){ if(e.target===this) closeVisitModal(); });
document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeVisitModal(); });
</script>
