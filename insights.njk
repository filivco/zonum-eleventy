layout: base.njk
title: "Zonum Insights — Análisis del mercado inmobiliario en Colombia"
description: "Análisis independientes del mercado inmobiliario en Colombia: valorización por ciudad, tendencias de arriendo, ROI por zona y guías para inversores."
extra_css: |
  /* Hero */
  .hero{background:#0D2B44;padding:56px 28px 48px;position:relative;overflow:hidden}
  .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 600px 300px at 80% 50%,rgba(26,79,122,0.3) 0%,transparent 70%)}
  .hero-inner{max-width:1200px;margin:0 auto;position:relative;z-index:1}
  .hero-eyebrow{font-size:11px;letter-spacing:0.14em;text-transform:uppercase;color:#B8975A;margin-bottom:12px;font-weight:500}
  .hero-title{font-family:var(--font-heading);font-size:38px;font-weight:500;color:#fff;line-height:1.15;margin-bottom:12px;max-width:640px}
  .hero-sub{font-size:14px;color:#A8C4DC;line-height:1.7;max-width:520px;margin-bottom:36px}
  .hero-search{display:flex;gap:0;max-width:480px}
  .hero-search input{flex:1;padding:12px 16px;background:rgba(255,255,255,0.08);border:0.5px solid rgba(168,196,220,0.25);border-right:none;border-radius:8px 0 0 8px;font-size:13px;color:#fff;font-family:inherit;outline:none}
  .hero-search input::placeholder{color:#5A8CB5}
  .hero-search button{padding:12px 20px;background:#B8975A;color:#fff;border:none;border-radius:0 8px 8px 0;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;white-space:nowrap}

  /* Filter pills */
  .filter-bar{background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);padding:0 28px}
  .filter-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:8px;padding:14px 0;flex-wrap:wrap}
  .filter-label{font-size:11px;color:#888078;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;margin-right:4px}
  .filter-pill{padding:6px 14px;border-radius:999px;font-size:12px;cursor:pointer;font-weight:500;border:0.5px solid var(--color-border-secondary);background:#fff;color:#6B6560;transition:all 0.15s;font-family:inherit}
  .filter-pill.active{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .filter-pill:hover:not(.active){background:#F2EEE6}

  /* Main layout */
  .main-inner{max-width:1200px;margin:0 auto;padding:40px 28px}

  /* Featured article */
  .featured{display:grid;grid-template-columns:1.4fr 1fr;gap:0;background:var(--color-background-primary);border-radius:20px;border:0.5px solid var(--color-border-tertiary);overflow:hidden;margin-bottom:40px;cursor:pointer}
  .featured:hover .featured-title{color:#1A4F7A}
  .featured-img{height:360px;object-fit:cover;width:100%;display:block;background:#DDE9F4}
  .featured-body{padding:40px}
  .featured-cat{font-size:10px;color:#B8975A;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;margin-bottom:14px;display:flex;align-items:center;gap:6px}
  .featured-cat::before{content:'★';color:#B8975A}
  .featured-title{font-family:var(--font-heading);font-size:26px;font-weight:500;color:#3A3530;line-height:1.2;margin-bottom:14px;transition:color 0.15s}
  .featured-excerpt{font-size:14px;color:#6B6560;line-height:1.7;margin-bottom:24px}
  .featured-meta{display:flex;align-items:center;gap:16px;font-size:11px;color:#888078;margin-bottom:28px}
  .featured-cta{display:inline-block;background:#1A4F7A;color:#fff;border:none;border-radius:8px;padding:11px 20px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;text-decoration:none}
  .featured-badge{display:inline-flex;align-items:center;gap:5px;background:#DDE9F4;border-radius:6px;padding:3px 10px;font-size:10px;font-weight:600;color:#1A4F7A;margin-bottom:16px}

  /* Articles grid */
  .section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
  .section-title{font-family:var(--font-heading);font-size:18px;font-weight:500;color:#3A3530}
  .section-link{font-size:12px;color:#1A4F7A;font-weight:500;cursor:pointer;text-decoration:none}
  .articles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
  .acard{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:16px;overflow:hidden;cursor:pointer;transition:box-shadow 0.2s}
  .acard:hover{box-shadow:0 4px 20px rgba(0,0,0,0.08)}
  .acard:hover .acard-title{color:#1A4F7A}
  .acard-img{height:160px;object-fit:cover;width:100%;display:block;background:var(--color-background-secondary)}
  .acard-body{padding:20px}
  .acard-cat{font-size:10px;color:#B8975A;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:8px}
  .acard-title{font-family:var(--font-heading);font-size:16px;font-weight:500;color:#3A3530;margin-bottom:8px;line-height:1.3;transition:color 0.15s}
  .acard-excerpt{font-size:12px;color:#6B6560;line-height:1.6;margin-bottom:14px}
  .acard-footer{display:flex;align-items:center;justify-content:space-between;font-size:11px;color:#888078}
  .acard-read{color:#1A4F7A;font-weight:500;font-size:11px}
  .acard-coming{display:inline-block;background:#F2EEE6;border-radius:4px;padding:2px 8px;font-size:10px;color:#888078;font-weight:500}

  /* Stats band */
  .stats-band{background:#EFF4F9;border-radius:16px;padding:28px;margin-bottom:48px;display:grid;grid-template-columns:repeat(4,1fr);gap:0}
  .stat-item{text-align:center;border-right:0.5px solid rgba(26,79,122,0.15);padding:0 20px}
  .stat-item:last-child{border-right:none}
  .stat-val{font-family:var(--font-heading);font-size:28px;font-weight:500;color:#1A4F7A;margin-bottom:4px}
  .stat-lbl{font-size:11px;color:#6B6560;line-height:1.4}

  /* Newsletter */
  .newsletter{background:#0D2B44;border-radius:20px;padding:48px;display:grid;grid-template-columns:1fr 400px;gap:40px;align-items:center;margin-bottom:40px}
  .nl-title{font-family:var(--font-heading);font-size:26px;font-weight:500;color:#fff;margin-bottom:8px;line-height:1.2}
  .nl-sub{font-size:14px;color:#A8C4DC;line-height:1.6}
  .nl-form{display:flex;flex-direction:column;gap:10px}
  .nl-input{padding:12px 16px;border:0.5px solid rgba(168,196,220,0.25);border-radius:8px;font-size:13px;color:#fff;font-family:inherit;background:rgba(255,255,255,0.07);outline:none}
  .nl-input::placeholder{color:#5A8CB5}
  .nl-btn{background:#B8975A;color:#fff;border:none;border-radius:8px;padding:12px;font-size:14px;font-weight:600;cursor:pointer;font-family:inherit}
  .nl-btn:hover{background:#A07A46}
  .nl-note{font-size:11px;color:#5A8CB5;line-height:1.5}

  /* City tabs */
  .city-tabs{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
  .city-tab{padding:7px 16px;border-radius:999px;font-size:12px;cursor:pointer;font-weight:500;border:0.5px solid var(--color-border-secondary);background:#fff;color:#6B6560;font-family:inherit}
  .city-tab.active{background:#1A4F7A;color:#fff;border-color:#1A4F7A}

  @media(max-width:900px){
    .featured{grid-template-columns:1fr}
    .featured-img{height:240px}
    .articles-grid{grid-template-columns:1fr 1fr}
    .newsletter{grid-template-columns:1fr}
    .stats-band{grid-template-columns:1fr 1fr}
    .stat-item:nth-child(2){border-right:none}
  }
  @media(max-width:600px){
    .hero-title{font-size:28px}
    .articles-grid{grid-template-columns:1fr}
    .stats-band{grid-template-columns:1fr 1fr}
    .newsletter{padding:28px}
  }
