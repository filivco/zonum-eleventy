<script>
(function(){
  var hBtn=document.getElementById('hamburgerBtn'),mMenu=document.getElementById('mobileMenu');
  if(hBtn)hBtn.addEventListener('click',function(e){e.stopPropagation();mMenu.classList.toggle('open');});
  document.addEventListener('click',function(e){if(mMenu&&!mMenu.contains(e.target)&&e.target!==hBtn)mMenu.classList.remove('open');});
})();

function doSearch(){
  var q=document.getElementById('search-input').value.trim().toLowerCase();
  if(!q) return;
  var cityMap={medellin:'medellin',medellín:'medellin',cartagena:'cartagena',bogota:'bogota',bogotá:'bogota',miami:'miami'};
  for(var key in cityMap){
    if(q.indexOf(key)>-1){location.href='/buscar/?ciudad='+cityMap[key];return;}
  }
  location.href='/buscar/';
}

function filterArticles(cat, btn){
  document.querySelectorAll('.filter-pill').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  var cards=document.querySelectorAll('.acard');
  cards.forEach(function(c){
    c.style.display=(cat==='all'||c.getAttribute('data-cat')===cat)?'block':'none';
  });
}

function filterCity(city, btn){
  document.querySelectorAll('.city-tab').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  var cards=document.querySelectorAll('.acard');
  cards.forEach(function(c){
    var cardCity=c.getAttribute('data-city');
    c.style.display=(city==='all'||cardCity==='all'||cardCity===city)?'block':'none';
  });
}

function subscribeNewsletter(){
  var n=document.getElementById('nl-name').value.trim();
  var e=document.getElementById('nl-email').value.trim();
  if(!n||!e||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)){
    alert('Por favor ingresa tu nombre y un correo válido.');return;
  }
  document.getElementById('nl-btn').style.display='none';
  document.getElementById('nl-success').style.display='block';
}
</script>
