extra_css: |
  /* ── Hero ── */
  .hero-band{background:#0D2B44;min-height:420px;display:flex;align-items:center;position:relative;overflow:hidden}
  .hero-inner{max-width:1200px;margin:0 auto;padding:56px 28px;width:100%;position:relative;z-index:1}
  .breadcrumb{font-size:12px;color:#A8C4DC;margin-bottom:20px;display:flex;align-items:center;gap:6px}
  .breadcrumb a{color:#A8C4DC;text-decoration:none}
  .breadcrumb a:hover{color:#fff}
  .breadcrumb-sep{color:#5A8CB5;font-size:10px}
  .hero-title{font-family:var(--font-heading);font-size:36px;font-weight:500;color:#fff;margin-bottom:10px;line-height:1.2}
  .hero-sub{font-size:14px;color:#A8C4DC;margin-bottom:40px;line-height:1.6;max-width:560px}
  .hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;max-width:900px}
  .stat-card{background:rgba(255,255,255,0.06);border:1px solid rgba(90,140,181,0.4);border-radius:var(--border-radius-lg);padding:18px 20px}
  .stat-value{font-family:var(--font-heading);font-size:22px;font-weight:500;color:#fff;margin-bottom:4px}
  .stat-label{font-size:11px;color:#A8C4DC;line-height:1.4}

  /* ── Section common ── */
  .section{padding:64px 28px}
  .section-inner{max-width:1200px;margin:0 auto}
  .section-title{font-family:var(--font-heading);font-size:26px;font-weight:500;color:var(--color-text-primary);margin-bottom:8px}
  .section-sub{font-size:14px;color:var(--color-text-secondary);line-height:1.7;margin-bottom:32px}
  .eyebrow{font-size:10px;font-weight:600;color:#1A4F7A;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:10px}

  /* ── Market overview ── */
  .market-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
  .market-text p{font-size:14px;color:var(--color-text-secondary);line-height:1.8;margin-bottom:14px}
  .market-text p:last-child{margin-bottom:0}
  .chart-wrap{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-xl);padding:28px}
  .chart-title{font-family:var(--font-heading);font-size:14px;color:var(--color-text-primary);margin-bottom:20px}
  .chart-bars{display:flex;align-items:flex-end;gap:12px;height:140px}
  .bar-col{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1}
  .bar{width:100%;background:#1A4F7A;border-radius:4px 4px 0 0;transition:opacity 0.2s}
  .bar:hover{opacity:0.8}
  .bar-val{font-size:10px;font-weight:600;color:#1A4F7A}
  .bar-yr{font-size:10px;color:var(--color-text-tertiary)}

  /* ── Neighborhoods ── */
  .neighborhoods-bg{background:var(--color-background-primary)}
  .nbhd-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
  .nbhd-card{border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:20px;background:#fff;transition:box-shadow 0.2s}
  .nbhd-card:hover{box-shadow:0 4px 16px rgba(0,0,0,0.07)}
  .nbhd-name{font-family:var(--font-heading);font-size:16px;font-weight:500;color:var(--color-text-primary);margin-bottom:12px}
  .nbhd-stat{display:flex;justify-content:space-between;align-items:center;font-size:12px;padding:6px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
  .nbhd-stat:last-of-type{border-bottom:none;margin-bottom:10px}
  .nbhd-stat-label{color:var(--color-text-secondary)}
  .nbhd-stat-value{font-weight:500;color:var(--color-text-primary)}
  .nbhd-roi{color:#1A4F7A;font-weight:600}
  .nbhd-desc{font-size:11px;color:var(--color-text-tertiary);line-height:1.5;padding-top:10px;border-top:0.5px solid var(--color-border-tertiary)}

  /* ── Project cards (lcard) ── */
  .lcard{border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);overflow:hidden;background:var(--color-background-primary);transition:box-shadow 0.2s}
  .lcard:hover{box-shadow:0 4px 16px rgba(0,0,0,0.07)}
  .lcard-img{height:130px;background:var(--color-background-secondary);position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden}
  .lcard-img svg{opacity:0.18}
  .lcard-body{padding:10px 12px}
  .lcard-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px}
  .lcard-price{font-size:15px;font-weight:500;color:var(--color-text-primary)}
  .lcard-name{font-family:var(--font-heading);font-size:14px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px}
  .lcard-loc{font-size:11px;color:var(--color-text-secondary);margin-bottom:8px}
  .lcard-specs{display:flex;gap:8px;font-size:10px;color:var(--color-text-secondary);padding-top:7px;border-top:0.5px solid var(--color-border-tertiary);margin-bottom:8px}
  .lcard-footer{display:flex;align-items:center;justify-content:space-between}
  .lcard-btn{font-size:11px;padding:5px 10px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);color:var(--color-text-primary);cursor:pointer;background:transparent;text-decoration:none;display:inline-block}
  .lcard-btn:hover{background:var(--color-background-secondary)}
  .projects-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
  .projects-badge{font-size:9px;font-weight:600;background:#DDE9F4;color:#1A4F7A;padding:3px 8px;border-radius:999px;letter-spacing:0.05em;text-transform:uppercase}
  .ncta{font-size:12px;padding:7px 14px;border-radius:var(--border-radius-md);cursor:pointer;border:0.5px solid var(--color-border-secondary);background:transparent;color:var(--color-text-primary)}
  .ncta-outline{color:#1A4F7A;border-color:#1A4F7A}

  /* ── Why invest ── */
  .why-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
  .why-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:24px}
  .why-icon{width:40px;height:40px;background:#DDE9F4;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}
  .why-title{font-family:var(--font-heading);font-size:15px;font-weight:500;color:var(--color-text-primary);margin-bottom:8px}
  .why-text{font-size:13px;color:var(--color-text-secondary);line-height:1.7}

  /* ── Investment guide ── */
  .guide-bg{background:var(--color-background-primary)}
  .guide-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px}
  .steps-list{display:flex;flex-direction:column;gap:20px}
  .step-item{display:flex;gap:16px;align-items:flex-start}
  .step-num{width:32px;height:32px;border-radius:50%;background:#0D2B44;color:#fff;font-family:var(--font-heading);font-size:14px;font-weight:500;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .step-content-title{font-family:var(--font-heading);font-size:14px;font-weight:500;color:var(--color-text-primary);margin-bottom:3px}
  .step-content-text{font-size:13px;color:var(--color-text-secondary);line-height:1.6}
  .calc-box{background:#fff;border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-xl);padding:28px}
  .calc-title{font-family:var(--font-heading);font-size:16px;font-weight:500;color:var(--color-text-primary);margin-bottom:6px}
  .calc-sub{font-size:12px;color:var(--color-text-secondary);margin-bottom:22px}
  .calc-label{font-size:11px;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px}
  .calc-input{width:100%;padding:11px 14px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);font-size:14px;color:var(--color-text-primary);font-family:inherit;outline:none;background:var(--color-background-secondary);transition:border-color 0.15s;margin-bottom:16px}
  .calc-input:focus{border-color:#1A4F7A}
  .calc-btn{width:100%;padding:12px;background:#1A4F7A;color:#fff;border:none;border-radius:var(--border-radius-md);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:background 0.15s;margin-bottom:18px}
  .calc-btn:hover{background:#0D2B44}
  .calc-results{display:none;background:#DDE9F4;border-radius:var(--border-radius-lg);padding:16px}
  .calc-results.show{display:block}
  .calc-result-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:0.5px solid rgba(26,79,122,0.15)}
  .calc-result-row:last-child{border-bottom:none}
  .calc-result-label{font-size:12px;color:#1A4F7A}
  .calc-result-value{font-family:var(--font-heading);font-size:15px;font-weight:500;color:#0D2B44}

  /* ── Curation band ── */
  .curation-band{background:#0D2B44;padding:56px 28px;text-align:center}
  .curation-inner{max-width:680px;margin:0 auto}
  .curation-eyebrow{font-size:10px;font-weight:600;color:#A8C4DC;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:14px}
  .curation-title{font-family:var(--font-heading);font-size:28px;font-weight:500;color:#fff;margin-bottom:10px;line-height:1.3}
  .curation-text{font-size:13px;color:#A8C4DC;line-height:1.7;margin-bottom:28px}
  .curation-cta{display:inline-block;padding:12px 28px;background:transparent;border:1px solid rgba(90,140,181,0.6);border-radius:var(--border-radius-md);color:#fff;font-size:13px;font-weight:500;text-decoration:none;cursor:pointer;transition:all 0.2s;font-family:inherit}
  .curation-cta:hover{background:rgba(255,255,255,0.08);border-color:#A8C4DC}

  /* ── Related cities ── */
  .cities-strip{padding:40px 28px;border-top:0.5px solid var(--color-border-tertiary)}
  .cities-inner{max-width:1200px;margin:0 auto}
  .cities-label{font-size:11px;font-weight:600;color:var(--color-text-tertiary);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:16px}
  .cities-row{display:flex;gap:10px;flex-wrap:wrap}
  .city-chip{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;border:0.5px solid var(--color-border-secondary);border-radius:999px;font-size:13px;color:var(--color-text-secondary);text-decoration:none;background:var(--color-background-primary);transition:all 0.15s;cursor:pointer}
  .city-chip:hover{border-color:#1A4F7A;color:#1A4F7A}

  /* ── Visit Modal CSS ── */
  .visit-modal{position:fixed;inset:0;background:rgba(13,43,68,0.72);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.25s}
  .visit-modal.open{opacity:1;pointer-events:all}
  .visit-box{background:#fff;max-width:840px;width:calc(100% - 32px);border-radius:20px;overflow:hidden;display:flex;position:relative;max-height:90vh}
  .visit-left{width:300px;min-width:300px;background:#0D2B44;padding:32px 28px;display:flex;flex-direction:column;gap:0;overflow-y:auto}
  .vl-logo{font-family:'clother',sans-serif;font-size:18px;font-weight:500;color:#fff;margin-bottom:20px;letter-spacing:0.02em}
  .vl-img-placeholder{width:100%;height:140px;border-radius:12px;background:linear-gradient(135deg,#1A4F7A,#0D2B44);margin-bottom:16px;display:flex;align-items:center;justify-content:center;font-size:32px}
  .vl-project-name{font-family:'clother',sans-serif;font-size:15px;font-weight:500;color:#fff;margin-bottom:3px}
  .vl-project-loc{font-size:12px;color:#A8C4DC;margin-bottom:20px;display:flex;align-items:center;gap:4px}
  .vl-trust{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
  .vl-trust-item{display:flex;align-items:center;gap:8px;font-size:12px;color:#C4D9ED;line-height:1.4}
  .vl-trust-check{width:18px;height:18px;border-radius:50%;background:rgba(90,140,181,0.25);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
  .vl-steps{display:flex;gap:6px;margin-top:auto;padding-top:16px}
  .vl-step-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.2);transition:all 0.25s}
  .vl-step-dot.active{background:#fff;width:20px;border-radius:4px}
  .visit-right{flex:1;padding:32px 28px;overflow-y:auto;background:#fff;position:relative}
  .visit-close{position:absolute;top:14px;right:14px;width:32px;height:32px;border-radius:50%;background:rgba(58,53,48,0.08);border:none;cursor:pointer;font-size:16px;color:#6B6560;display:flex;align-items:center;justify-content:center;transition:background 0.15s;z-index:1}
  .visit-close:hover{background:rgba(58,53,48,0.14)}
  .visit-step{display:none}
  .visit-step.active{display:block}
  .vstep-eyebrow{font-size:10px;color:#6B6560;text-transform:uppercase;letter-spacing:0.08em;font-weight:500;margin-bottom:6px}
  .vstep-title{font-family:'clother',sans-serif;font-size:20px;font-weight:500;color:#3A3530;margin-bottom:4px}
  .vstep-sub{font-size:12px;color:#6B6560;margin-bottom:22px;line-height:1.5}
  .city-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px}
  .city-pill{font-size:12px;padding:7px 14px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .city-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .city-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .project-select-wrap{margin-bottom:18px;display:none}
  .project-select-wrap.show{display:block}
  .project-select-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:7px}
  .project-select{width:100%;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:8px;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;cursor:pointer;appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%236b6b68' stroke-width='1.2' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;transition:border-color 0.15s}
  .project-select:focus{border-color:#1A4F7A}
  .visit-type-toggle{display:flex;gap:8px;margin-bottom:20px}
  .vtype-pill{flex:1;padding:10px;border-radius:10px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;text-align:center;font-size:13px;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .vtype-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .vtype-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .cal-wrap{margin-bottom:18px}
  .cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .cal-month{font-size:14px;font-weight:500;color:#3A3530;font-family:'clother',sans-serif}
  .cal-nav-btn{width:28px;height:28px;border-radius:50%;border:0.5px solid rgba(58,53,48,0.22);background:transparent;cursor:pointer;font-size:12px;color:#6B6560;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
  .cal-nav-btn:hover{border-color:#1A4F7A;color:#1A4F7A}
  .cal-days-header{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px}
  .cal-day-label{text-align:center;font-size:10px;font-weight:600;color:#888078;padding:4px 0;text-transform:uppercase;letter-spacing:0.04em}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
  .cal-day{width:100%;aspect-ratio:1;border-radius:50%;border:none;background:transparent;cursor:default;font-size:12px;color:#3A3530;display:flex;align-items:center;justify-content:center;transition:all 0.15s;font-family:inherit;position:relative}
  .cal-day.empty{pointer-events:none}
  .cal-day.past{color:rgba(58,53,48,0.25);pointer-events:none}
  .cal-day.avail{cursor:pointer;font-weight:500}
  .cal-day.avail:hover{background:#DDE9F4;color:#1A4F7A}
  .cal-day.sel{background:#1A4F7A !important;color:#fff !important;font-weight:600}
  .time-slots-wrap{display:none}
  .time-slots-wrap.show{display:block}
  .time-slots-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px}
  .time-slots{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px}
  .time-slot{font-size:12px;padding:7px 12px;border-radius:8px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .time-slot:hover:not(.off){border-color:#1A4F7A;color:#1A4F7A}
  .time-slot.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .time-slot.off{color:rgba(58,53,48,0.3);border-color:rgba(58,53,48,0.1);background:transparent;cursor:not-allowed;text-decoration:line-through}
  .visit-input-group{margin-bottom:13px}
  .visit-input-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px}
  .visit-input{width:100%;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:8px;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;transition:border-color 0.15s}
  .visit-input:focus{border-color:#1A4F7A}
  .visit-phone-row{display:flex;gap:0}
  .visit-phone-flag{padding:10px 12px;border:0.5px solid rgba(58,53,48,0.22);border-right:none;border-radius:8px 0 0 8px;font-size:13px;background:#F8F6F2;color:#3A3530;cursor:default;white-space:nowrap}
  .visit-phone-input{flex:1;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:0 8px 8px 0;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;transition:border-color 0.15s}
  .visit-phone-input:focus{border-color:#1A4F7A}
  .investor-pills{display:flex;flex-wrap:wrap;gap:7px}
  .investor-pill{font-size:12px;padding:7px 13px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .investor-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .investor-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .budget-pills{display:flex;flex-wrap:wrap;gap:7px}
  .budget-pill{font-size:12px;padding:7px 13px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .budget-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .budget-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .visit-privacy{font-size:10px;color:#888078;line-height:1.6;margin-top:14px;margin-bottom:16px}
  .visit-privacy a{color:#1A4F7A;text-decoration:none}
  .visit-cta{width:100%;padding:13px;background:#1A4F7A;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:background 0.15s;font-family:inherit;letter-spacing:0.02em}
  .visit-cta:hover:not(:disabled){background:#0D2B44}
  .visit-cta:disabled{background:rgba(58,53,48,0.2);color:rgba(58,53,48,0.4);cursor:not-allowed}
  .visit-back{background:transparent;border:none;color:#6B6560;font-size:13px;cursor:pointer;padding:10px 0;font-family:inherit;display:inline-flex;align-items:center;gap:4px;margin-top:8px;transition:color 0.15s}
  .visit-back:hover{color:#3A3530}
  .confirm-box{background:#DDE9F4;border-radius:12px;padding:16px;margin-bottom:18px}
  .confirm-box-title{font-size:11px;font-weight:600;color:#0D2B44;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:10px}
  .confirm-row{display:flex;align-items:center;gap:8px;font-size:13px;color:#1A4F7A;margin-bottom:6px}
  .confirm-row:last-child{margin-bottom:0}
  .confirm-icon{font-size:14px;flex-shrink:0}
  .next-steps{margin-bottom:18px}
  .next-steps-title{font-size:12px;font-weight:600;color:#3A3530;margin-bottom:10px}
  .next-step-item{display:flex;align-items:flex-start;gap:10px;font-size:12px;color:#6B6560;margin-bottom:8px;line-height:1.5}
  .next-step-num{width:20px;height:20px;border-radius:50%;background:#DDE9F4;color:#1A4F7A;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .visit-outline-btn{width:100%;padding:11px;background:transparent;border:0.5px solid #1A4F7A;border-radius:10px;font-size:13px;font-weight:500;color:#1A4F7A;cursor:pointer;font-family:inherit;transition:all 0.15s;margin-bottom:10px;text-align:center;text-decoration:none;display:block}
  .visit-outline-btn:hover{background:#DDE9F4}
  .visit-dismiss-link{display:block;text-align:center;font-size:12px;color:#888078;cursor:pointer;margin-top:4px;transition:color 0.15s}
  .visit-dismiss-link:hover{color:#3A3530}

  /* ── Responsive ── */
  @media(max-width:900px){
    .hero-stats{grid-template-columns:repeat(2,1fr)}
    .market-grid{grid-template-columns:1fr}
    .nbhd-grid{grid-template-columns:repeat(2,1fr)}
    .projects-grid{grid-template-columns:repeat(2,1fr)}
    .why-grid{grid-template-columns:repeat(2,1fr)}
    .guide-grid{grid-template-columns:1fr}
  }
  @media(max-width:560px){
    .hero-stats{grid-template-columns:1fr 1fr}
    .hero-title{font-size:26px}
    .nbhd-grid{grid-template-columns:1fr}
    .projects-grid{grid-template-columns:1fr}
    .why-grid{grid-template-columns:1fr}
    .visit-box{flex-direction:column;max-height:95vh;border-radius:16px 16px 0 0;position:fixed;bottom:0;left:0;right:0;width:100%;margin:0}
    .visit-left{display:none}
    .visit-right{padding:24px 20px 20px}
    .visit-modal{align-items:flex-end}
  }
