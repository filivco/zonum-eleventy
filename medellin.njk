/* ════════════════════════════════════════
   BAR CHART — valorización anual
════════════════════════════════════════ */
(function(){
  var data = [
    {yr:'2019', val:6.2},
    {yr:'2020', val:4.1},
    {yr:'2021', val:7.8},
    {yr:'2022', val:9.2},
    {yr:'2023', val:8.8},
    {yr:'2024', val:10.1}
  ];
  var maxVal = 12;
  var container = document.getElementById('chartBars');
  if (!container) return;
  data.forEach(function(d){
    var col = document.createElement('div');
    col.className = 'bar-col';
    var pct = (d.val / maxVal * 100).toFixed(1);
    col.innerHTML =
      '<span class="bar-val">'+d.val+'%</span>' +
      '<div class="bar" style="height:'+pct+'%;min-height:8px"></div>' +
      '<span class="bar-yr">'+d.yr+'</span>';
    container.appendChild(col);
  });
})();

/* ════════════════════════════════════════
   ROI CALCULATOR
════════════════════════════════════════ */
function calcROI() {
  var precio = parseFloat(document.getElementById('calcPrecio').value);
  var roi = parseFloat(document.getElementById('calcZona').value);
  var results = document.getElementById('calcResults');
  if (!precio || precio < 100000000) { results.classList.remove('show'); return; }
  var arriendoAnual = precio * (roi / 100);
  var arriendoMensual = arriendoAnual / 12;
  var valorFuturo = precio * 1.41;
  var plusvalia = valorFuturo - precio;
  function fmt(n) {
    if (n >= 1000000000) return '$' + (n / 1000000000).toFixed(2) + 'B COP';
    return '$' + Math.round(n / 1000000) + 'M COP';
  }
  document.getElementById('res-arriendo').textContent = fmt(arriendoMensual) + '/mes';
  document.getElementById('res-roi').textContent = roi + '% anual';
  document.getElementById('res-val').textContent = '+' + fmt(plusvalia);
  document.getElementById('res-total').textContent = fmt(valorFuturo);
  results.classList.add('show');
}

/* ════════════════════════════════════════
   VISIT MODAL
════════════════════════════════════════ */
(function(){
  var vState = {
    step: 1,
    city: 'Medellín',
    project: '',
    visitType: 'Virtual',
    calYear: 0,
    calMonth: 0,
    selDate: null,
    selTime: '',
    availDays: []
  };

  var cityProjects = {
    'Bogotá': ['Park 100','Nórdika','Reserva El Nogal','Urbano 93'],
    'Medellín': ['Alma Luxury Lofts','Parque 93 Residences','Envigado Park','Torre Laureles','Lofts del Centro','Poblado Sky'],
    'Cartagena': ['Baru Bay','Lagoon House','Marina del Caribe','Vistas del Mar'],
    'Santa Marta': ['Kashi Santa Marta','Bello Horizonte','Playa Salguero','El Rodadero'],
    'Cali': ['Ciudad Jardín','Menga Hills','La Flora','Chipichape Loft'],
    'Barranquilla': ['Prado Living','El Prado Sky','Miramar 80','Caribe View'],
    'Otra ciudad': ['Proyecto en otra ciudad']
  };

  var allSlots = ['9:00 am','10:00 am','11:00 am','2:00 pm','3:00 pm','4:00 pm','5:00 pm'];
  var offSlots = ['11:00 am','4:00 pm'];

  window.openVisitModal = function(projectName, city) {
    resetModal();
    var targetCity = city || 'Medellín';
    vState.city = targetCity;
    document.querySelectorAll('.city-pill').forEach(function(p){
      p.classList.toggle('sel', p.textContent.trim().indexOf(targetCity) !== -1);
    });
    showProjectSelect(targetCity);
    if (projectName) {
      vState.project = projectName;
      setTimeout(function(){
        var sel = document.getElementById('projectSelect');
        for (var i = 0; i < sel.options.length; i++) {
          if (sel.options[i].value === projectName) { sel.selectedIndex = i; break; }
        }
        onProjectChange();
      }, 50);
    }
    updateLeftPanel();
    document.getElementById('visitModal').classList.add('open');
    document.body.style.overflow = 'hidden';
  };

  window.closeVisitModal = function() {
    document.getElementById('visitModal').classList.remove('open');
    document.body.style.overflow = '';
  };

  function resetModal() {
    vState = { step:1, city:'Medellín', project:'', visitType:'Virtual', calYear:0, calMonth:0, selDate:null, selTime:'', availDays:[] };
    goToStep(1);
    document.querySelectorAll('.city-pill').forEach(function(p){ p.classList.remove('sel'); });
    document.querySelectorAll('.investor-pill,.budget-pill').forEach(function(p){ p.classList.remove('sel'); });
    document.getElementById('projectSelectWrap').classList.remove('show');
    document.getElementById('visitNombre').value = '';
    document.getElementById('visitEmail').value = '';
    document.getElementById('visitTel').value = '';
    document.getElementById('step1Cta').disabled = true;
    document.getElementById('step2Cta').disabled = true;
    document.getElementById('step3Cta').disabled = true;
    document.getElementById('vtype-virtual').classList.add('sel');
    document.getElementById('vtype-presencial').classList.remove('sel');
    vState.visitType = 'Virtual';
  }

  window.nextStep = function() {
    if (vState.step < 4) { vState.step++; goToStep(vState.step); }
  };
  window.prevStep = function() {
    if (vState.step > 1) { vState.step--; goToStep(vState.step); }
  };

  function goToStep(n) {
    vState.step = n;
    for (var i = 1; i <= 4; i++) {
      var s = document.getElementById('vstep-' + i);
      if (s) s.classList.toggle('active', i === n);
    }
    for (var j = 1; j <= 3; j++) {
      var d = document.getElementById('vldot-' + j);
      if (d) d.classList.toggle('active', j === n || j < n);
    }
    if (n === 2) { initCalendar(); }
    document.getElementById('visitModal').querySelector('.visit-right').scrollTop = 0;
  }

  window.selectCity = function(city, el) {
    vState.city = city;
    vState.project = '';
    document.querySelectorAll('.city-pill').forEach(function(p){ p.classList.remove('sel'); });
    el.classList.add('sel');
    showProjectSelect(city);
    document.getElementById('step1Cta').disabled = true;
    updateLeftPanel();
  };

  function showProjectSelect(city) {
    var wrap = document.getElementById('projectSelectWrap');
    wrap.classList.add('show');
    var sel = document.getElementById('projectSelect');
    sel.innerHTML = '<option value="">Seleccionar proyecto...</option>';
    var projs = cityProjects[city] || [];
    projs.forEach(function(p) {
      var o = document.createElement('option');
      o.value = p; o.textContent = p;
      sel.appendChild(o);
    });
    vState.project = '';
  }

  window.onProjectChange = function() {
    var sel = document.getElementById('projectSelect');
    vState.project = sel.value;
    document.getElementById('step1Cta').disabled = !vState.project;
    updateLeftPanel();
  };

  window.selectVisitType = function(type, el) {
    vState.visitType = type;
    document.querySelectorAll('.vtype-pill').forEach(function(p){ p.classList.remove('sel'); });
    el.classList.add('sel');
  };

  window.selectPill = function(el, group) {
    el.parentElement.querySelectorAll('button').forEach(function(b){ b.classList.remove('sel'); });
    el.classList.add('sel');
    validateStep3();
  };

  function initCalendar() {
    var now = new Date();
    if (!vState.calYear) {
      vState.calYear = now.getFullYear();
      vState.calMonth = now.getMonth();
    }
    renderCalendar();
  }

  window.changeMonth = function(dir) {
    vState.calMonth += dir;
    if (vState.calMonth > 11) { vState.calMonth = 0; vState.calYear++; }
    if (vState.calMonth < 0) { vState.calMonth = 11; vState.calYear--; }
    vState.selDate = null;
    vState.selTime = '';
    document.getElementById('step2Cta').disabled = true;
    document.getElementById('timeSlotsWrap').classList.remove('show');
    renderCalendar();
  };

  function renderCalendar() {
    var months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    document.getElementById('calMonth').textContent = months[vState.calMonth] + ' ' + vState.calYear;
    var grid = document.getElementById('calGrid');
    grid.innerHTML = '';
    var today = new Date();
    today.setHours(0,0,0,0);
    var firstDay = new Date(vState.calYear, vState.calMonth, 1);
    var lastDay = new Date(vState.calYear, vState.calMonth + 1, 0);
    var startDow = (firstDay.getDay() + 6) % 7;
    var availSet = {};
    var seed = [2,3,5,7,9,10,12,14,16,17,19,21,23,24,26,28];
    seed.forEach(function(d){ if (d <= lastDay.getDate()) availSet[d] = true; });
    for (var e = 0; e < startDow; e++) {
      var empty = document.createElement('div');
      empty.className = 'cal-day empty';
      grid.appendChild(empty);
    }
    for (var d = 1; d <= lastDay.getDate(); d++) {
      var cell = document.createElement('button');
      cell.textContent = d;
      var thisDate = new Date(vState.calYear, vState.calMonth, d);
      if (thisDate < today) {
        cell.className = 'cal-day past';
        cell.disabled = true;
      } else if (availSet[d]) {
        cell.className = 'cal-day avail';
        if (vState.selDate && vState.selDate.getDate() === d &&
            vState.selDate.getMonth() === vState.calMonth &&
            vState.selDate.getFullYear() === vState.calYear) {
          cell.classList.add('sel');
        }
        (function(day, btn){ btn.onclick = function(){ selectDay(day, btn); }; })(thisDate, cell);
      } else {
        cell.className = 'cal-day past';
        cell.disabled = true;
      }
      grid.appendChild(cell);
    }
  }

  function selectDay(date, btn) {
    vState.selDate = date;
    vState.selTime = '';
    document.getElementById('step2Cta').disabled = true;
    document.querySelectorAll('#calGrid .cal-day').forEach(function(c){ c.classList.remove('sel'); });
    btn.classList.add('sel');
    renderTimeSlots();
    document.getElementById('timeSlotsWrap').classList.add('show');
  }

  function renderTimeSlots() {
    var container = document.getElementById('timeSlots');
    container.innerHTML = '';
    allSlots.forEach(function(t) {
      var btn = document.createElement('button');
      btn.className = 'time-slot' + (offSlots.indexOf(t) !== -1 ? ' off' : '');
      btn.textContent = t;
      if (offSlots.indexOf(t) === -1) {
        btn.onclick = function() {
          vState.selTime = t;
          document.querySelectorAll('.time-slot').forEach(function(s){ s.classList.remove('sel'); });
          btn.classList.add('sel');
          document.getElementById('step2Cta').disabled = false;
        };
      }
      container.appendChild(btn);
    });
  }

  window.validateStep3 = function() {
    var nombre = document.getElementById('visitNombre').value.trim();
    var email = document.getElementById('visitEmail').value.trim();
    var emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    document.getElementById('step3Cta').disabled = !(nombre && emailOk);
  };

  window.submitVisit = function() {
    var months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    document.getElementById('confirm-project').textContent = vState.project || 'Proyecto seleccionado';
    var dateStr = vState.selDate
      ? (vState.selDate.getDate() + ' de ' + months[vState.selDate.getMonth()] + ' ' + vState.selDate.getFullYear())
      : '—';
    document.getElementById('confirm-date').textContent = dateStr;
    document.getElementById('confirm-time').textContent = vState.selTime || '—';
    document.getElementById('confirm-type').textContent = vState.visitType;
    goToStep(4);
  };

  function updateLeftPanel() {
    var name = vState.project || (vState.city ? 'Proyectos en ' + vState.city : 'Proyectos seleccionados');
    var loc = vState.city || 'Medellín';
    document.getElementById('vl-project-name').textContent = name;
    document.getElementById('vl-project-loc-text').textContent = loc;
  }

  document.addEventListener('keydown', function(e){
    if (e.key === 'Escape') closeVisitModal();
  });
  document.getElementById('visitModal').addEventListener('click', function(e){
    if (e.target === this) closeVisitModal();
  });

})();
</script>
