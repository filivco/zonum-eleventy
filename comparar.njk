/* Metrics definition: key, label, higherIsBetter (true), or lowerIsBetter (false) */
var metrics = [
  { key: 'precio',     label: 'Precio desde',        compare: false, render: function(p){ return p.precio; } },
  { key: 'city',       label: 'Ciudad',               compare: null,  render: function(p){ return p.city; } },
  { key: 'tipo',       label: 'Tipo',                 compare: null,  render: function(p){ return p.tipo; } },
  { key: 'area',       label: 'Área mín / máx',       compare: true,  numKey: 'areaMax', render: function(p){ return p.areaMin + ' – ' + p.areaMax + ' m²'; } },
  { key: 'entrega',    label: 'Entrega estimada',     compare: null,  render: function(p){ return p.entrega; } },
  { key: 'roi',        label: 'ROI estimado',         compare: true,  numKey: 'roi', render: function(p){ return p.roiStr; } },
  { key: 'tir',        label: 'TIR proyectada',       compare: true,  numKey: 'tir', render: function(p){ return p.tirStr; } },
  { key: 'plusvalia',  label: 'Plusvalía esperada',   compare: true,  numKey: 'plusvalia', render: function(p){ return p.plusvaliaStr; } },
  { key: 'score',      label: 'Score Zonum',          compare: true,  numKey: 'score', render: null },
  { key: 'unidades',   label: 'Unidades disponibles', compare: false, numKey: 'unidades', render: function(p){ return p.unidades + ' uds.'; } },
  { key: 'constructora', label: 'Constructora',       compare: null,  render: function(p){ return p.constructora; } },
  { key: 'estado',     label: 'Estado obra',          compare: null,  render: function(p){ return p.estado; } }
];

var selected = [null, null, null];

window.onSelectChange = function(col) {
  var val = document.getElementById('sel' + col).value;
  selected[col] = val || null;
  renderCompare();
};

function renderCompare() {
  var filled = selected.filter(function(s){ return s; });
  var emptyState = document.getElementById('emptyState');
  var compareSection = document.getElementById('compareSection');

  if (filled.length < 2) {
    emptyState.style.display = 'block';
    compareSection.style.display = 'none';
    return;
  }

  emptyState.style.display = 'none';
  compareSection.style.display = 'block';

  var hasTh2 = !!selected[2];
  document.getElementById('th2').style.display = hasTh2 ? '' : 'none';

  /* Render column headers */
  for (var c = 0; c < 3; c++) {
    var th = document.getElementById('th' + c);
    if (selected[c]) {
      var p = projects[selected[c]];
      th.innerHTML = '<div class="proj-name">' + p.name + '</div><div class="proj-city">' + p.city + '</div>';
    } else {
      th.innerHTML = '';
    }
    if (c === 2) th.style.display = hasTh2 ? '' : 'none';
  }

  /* Render table body */
  var tbody = document.getElementById('compareBody');
  tbody.innerHTML = '';

  metrics.forEach(function(m) {
    var tr = document.createElement('tr');

    /* Label cell */
    var labelTd = document.createElement('td');
    labelTd.textContent = m.label;
    tr.appendChild(labelTd);

    /* Determine winner column index for numeric metrics */
    var winnerCol = -1;
    if (m.compare !== null && m.numKey) {
      var vals = [];
      for (var c = 0; c < 3; c++) {
        if (selected[c]) vals.push({ col: c, val: projects[selected[c]][m.numKey] });
      }
      if (vals.length >= 2) {
        if (m.compare === true) {
          vals.sort(function(a,b){ return b.val - a.val; });
        } else {
          vals.sort(function(a,b){ return a.val - b.val; });
        }
        winnerCol = vals[0].col;
      }
    }

    /* Data cells */
    for (var col = 0; col < 3; col++) {
      var td = document.createElement('td');
      if (col === 2) td.style.display = hasTh2 ? '' : 'none';

      if (!selected[col]) {
        td.className = 'empty-cell';
        td.textContent = '—';
        tr.appendChild(td);
        continue;
      }

      var proj = projects[selected[col]];
      if (winnerCol === col) td.classList.add('winner');

      if (m.key === 'score') {
        /* Score bar */
        var wrap = document.createElement('div');
        wrap.className = 'score-bar-wrap';
        var track = document.createElement('div');
        track.className = 'score-bar-track';
        var fill = document.createElement('div');
        fill.className = 'score-bar-fill';
        fill.style.width = (proj.score * 10) + '%';
        var scoreVal = document.createElement('span');
        scoreVal.className = 'score-val';
        scoreVal.textContent = proj.score;
        track.appendChild(fill);
        wrap.appendChild(track);
        wrap.appendChild(scoreVal);
        td.appendChild(wrap);
      } else {
        td.textContent = m.render(proj);
      }

      tr.appendChild(td);
    }

    tbody.appendChild(tr);
  });

  /* CTA row */
  renderCtaRow(hasTh2);
}

function renderCtaRow(hasTh2) {
  var ctaRow = document.getElementById('ctaRow');
  ctaRow.innerHTML = '';

  /* Match grid to number of active columns */
  var activeCols = selected.filter(function(s){ return s; }).length;
  ctaRow.style.gridTemplateColumns = 'repeat(' + activeCols + ',1fr)';

  var rendered = 0;
  for (var c = 0; c < 3; c++) {
    if (!selected[c]) continue;
    var p = projects[selected[c]];
    var card = document.createElement('div');
    card.className = 'cta-card';
    card.innerHTML =
      '<div class="cta-card-name">' + p.name + '</div>' +
      '<div class="cta-card-price">Desde ' + p.precio + '</div>' +
      '<button class="cta-btn" onclick="openVisitModal(\'' + p.name + '\',\'' + p.city + '\')">Agendar visita</button>' +
      '<a href="#" class="cta-link">Ver ficha completa →</a>';
    ctaRow.appendChild(card);
    rendered++;
  }
}

/* ── Hamburger ── */
var hamburger = document.getElementById('hamburgerBtn');
var mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', function(e){
  e.stopPropagation();
  mobileMenu.classList.toggle('open');
});
document.addEventListener('click', function(e){
  if (!mobileMenu.contains(e.target) && e.target !== hamburger) {
    mobileMenu.classList.remove('open');
  }
});

/* ── Visit Modal ── */
var vState = { step:1, city:'', project:'', visitType:'Virtual', calYear:0, calMonth:0, selDate:null, selTime:'', availDays:[] };
var cityProjects = {
  'Bogotá': ['Parque 93 Residences','Park 100','Reserva El Nogal'],
