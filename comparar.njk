---
layout: base.njk
title: "Comparar proyectos inmobiliarios · Zonum"
description: "Compara lado a lado los mejores proyectos inmobiliarios nuevos en Colombia. ROI, precio, entrega, score Zonum."
extra_css: |
  /* ── Page layout ── */
  .page-inner{max-width:1200px;margin:0 auto;padding:48px 28px 80px}

  /* ── Breadcrumb ── */
  .breadcrumb{font-size:12px;color:var(--color-text-tertiary);margin-bottom:20px;display:flex;align-items:center;gap:6px}
  .breadcrumb a{color:var(--color-text-tertiary);text-decoration:none}
  .breadcrumb a:hover{color:var(--azul-base)}
  .breadcrumb-sep{color:var(--color-border-secondary)}

  /* ── Page header ── */
  .page-header{margin-bottom:40px}
  .page-title{font-family:var(--font-heading);font-size:32px;font-weight:500;color:var(--color-text-primary);margin-bottom:8px;line-height:1.2}
  .page-sub{font-size:14px;color:var(--color-text-secondary);line-height:1.6}

  /* ── Selector grid ── */
  .selector-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px}
  .selector-col{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:18px 20px}
  .selector-label{font-size:10px;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px}
  .selector-select{width:100%;padding:10px 14px;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);font-size:13px;color:var(--color-text-primary);font-family:inherit;outline:none;background:var(--color-background-secondary);cursor:pointer;appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%236b6b68' stroke-width='1.2' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;transition:border-color 0.15s}
  .selector-select:focus{border-color:var(--azul-base)}
  .selector-num{font-size:11px;color:var(--color-text-tertiary);margin-bottom:4px}

  /* ── Comparison table ── */
  #compareSection{display:none}
  .compare-table-wrap{overflow-x:auto;border-radius:var(--border-radius-lg);border:0.5px solid var(--color-border-tertiary);background:var(--color-background-primary);margin-bottom:32px}
  .compare-table{width:100%;border-collapse:collapse;min-width:600px}
  .compare-table th{padding:16px 20px;font-size:11px;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.07em;border-bottom:0.5px solid var(--color-border-tertiary);text-align:left;background:var(--color-background-secondary)}
  .compare-table th.proj-col{text-align:left}
  .compare-table td{padding:14px 20px;font-size:13px;color:var(--color-text-primary);border-bottom:0.5px solid var(--color-border-tertiary);vertical-align:middle}
  .compare-table td:first-child{font-size:11px;font-weight:600;color:var(--color-text-secondary);text-transform:uppercase;letter-spacing:0.06em;width:170px;background:var(--color-background-secondary)}
  .compare-table tr:last-child td{border-bottom:none}
  .compare-table td.winner{background:#DDE9F4}
  .compare-table td.empty-cell{color:var(--color-text-tertiary);font-style:italic}

  /* Project header in table */
  .proj-header-cell{background:var(--color-background-primary) !important}
  .proj-name{font-family:var(--font-heading);font-size:14px;font-weight:500;color:var(--color-text-primary);margin-bottom:2px}
  .proj-city{font-size:11px;color:var(--color-text-secondary)}

  /* Score bar */
  .score-bar-wrap{display:flex;align-items:center;gap:10px}
  .score-bar-track{flex:1;height:6px;background:rgba(58,53,48,0.1);border-radius:3px;overflow:hidden;min-width:60px}
  .score-bar-fill{height:100%;border-radius:3px;background:var(--azul-base);transition:width 0.4s ease}
  .score-val{font-size:13px;font-weight:600;color:var(--azul-base);min-width:24px}

  /* ── CTA row ── */
  .cta-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:40px}
  .cta-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:var(--border-radius-lg);padding:20px;display:flex;flex-direction:column;gap:12px}
  .cta-card-name{font-family:var(--font-heading);font-size:15px;font-weight:500;color:var(--color-text-primary)}
  .cta-card-price{font-size:18px;font-weight:700;color:var(--azul-base)}
  .cta-btn{width:100%;padding:11px;background:var(--azul-base);color:#fff;border:none;border-radius:var(--border-radius-md);font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;transition:background 0.15s}
  .cta-btn:hover{background:var(--azul-noche)}
  .cta-link{display:block;text-align:center;font-size:12px;color:var(--azul-base);cursor:pointer;text-decoration:none;margin-top:2px}
  .cta-link:hover{text-decoration:underline}

  /* ── Empty state ── */
  #emptyState{text-align:center;padding:60px 20px}
  .empty-svg{margin:0 auto 24px;display:block}
  .empty-title{font-family:var(--font-heading);font-size:20px;color:var(--color-text-primary);margin-bottom:8px}
  .empty-sub{font-size:14px;color:var(--color-text-secondary);line-height:1.6}

  /* ── Visit Modal ── */
  .visit-modal{position:fixed;inset:0;background:rgba(13,43,68,0.72);backdrop-filter:blur(4px);z-index:1000;display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity 0.25s}
  .visit-modal.open{opacity:1;pointer-events:all}
  .visit-box{background:#fff;max-width:840px;width:calc(100% - 32px);border-radius:20px;overflow:hidden;display:flex;position:relative;max-height:90vh}
  .visit-left{width:300px;min-width:300px;background:#0D2B44;padding:32px 28px;display:flex;flex-direction:column;gap:0;overflow-y:auto}
  .vl-logo{font-family:'clother',sans-serif;font-size:18px;font-weight:500;color:#fff;margin-bottom:20px;letter-spacing:0.02em}
  .vl-img-placeholder{width:100%;height:140px;border-radius:12px;background:linear-gradient(135deg,#1A4F7A,#0D2B44);margin-bottom:16px;display:flex;align-items:center;justify-content:center;font-size:32px}
  .vl-project-name{font-family:'clother',sans-serif;font-size:15px;font-weight:500;color:#fff;margin-bottom:3px}
  .vl-project-loc{font-size:12px;color:#A8C4DC;margin-bottom:20px;display:flex;align-items:center;gap:4px}
  .vl-trust{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
  .vl-trust-item{display:flex;align-items:center;gap:8px;font-size:12px;color:#C4D9ED;line-height:1.4}
  .vl-trust-check{width:18px;height:18px;border-radius:50%;background:rgba(90,140,181,0.25);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}
  .vl-steps{display:flex;gap:6px;margin-top:auto;padding-top:16px}
  .vl-step-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.2);transition:all 0.25s}
  .vl-step-dot.active{background:#fff;width:20px;border-radius:4px}
  .visit-right{flex:1;padding:32px 28px;overflow-y:auto;background:#fff;position:relative}
  .visit-close{position:absolute;top:14px;right:14px;width:32px;height:32px;border-radius:50%;background:rgba(58,53,48,0.08);border:none;cursor:pointer;font-size:16px;color:#6B6560;display:flex;align-items:center;justify-content:center;transition:background 0.15s;z-index:1}
  .visit-close:hover{background:rgba(58,53,48,0.14)}
  .visit-step{display:none}
  .visit-step.active{display:block}
  .vstep-eyebrow{font-size:10px;color:#6B6560;text-transform:uppercase;letter-spacing:0.08em;font-weight:500;margin-bottom:6px}
  .vstep-title{font-family:'clother',sans-serif;font-size:20px;font-weight:500;color:#3A3530;margin-bottom:4px}
  .vstep-sub{font-size:12px;color:#6B6560;margin-bottom:22px;line-height:1.5}
  .city-pills{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:18px}
  .city-pill{font-size:12px;padding:7px 14px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .city-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .city-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .project-select-wrap{margin-bottom:18px;display:none}
  .project-select-wrap.show{display:block}
  .project-select-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:7px}
  .project-select{width:100%;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:8px;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;cursor:pointer;appearance:none;-webkit-appearance:none;background-image:url("data:image/svg+xml,%3Csvg width='10' height='6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%236b6b68' stroke-width='1.2' stroke-linecap='round'/%3E%3C/svg%3E");background-repeat:no-repeat;background-position:right 12px center;transition:border-color 0.15s}
  .project-select:focus{border-color:#1A4F7A}
  .visit-type-toggle{display:flex;gap:8px;margin-bottom:20px}
  .vtype-pill{flex:1;padding:10px;border-radius:10px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;text-align:center;font-size:13px;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .vtype-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .vtype-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .cal-wrap{margin-bottom:18px}
  .cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
  .cal-month{font-size:14px;font-weight:500;color:#3A3530;font-family:'clother',sans-serif}
  .cal-nav-btn{width:28px;height:28px;border-radius:50%;border:0.5px solid rgba(58,53,48,0.22);background:transparent;cursor:pointer;font-size:12px;color:#6B6560;display:flex;align-items:center;justify-content:center;transition:all 0.15s}
  .cal-nav-btn:hover{border-color:#1A4F7A;color:#1A4F7A}
  .cal-days-header{display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px}
  .cal-day-label{text-align:center;font-size:10px;font-weight:600;color:#888078;padding:4px 0;text-transform:uppercase;letter-spacing:0.04em}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
  .cal-day{width:100%;aspect-ratio:1;border-radius:50%;border:none;background:transparent;cursor:default;font-size:12px;color:#3A3530;display:flex;align-items:center;justify-content:center;transition:all 0.15s;font-family:inherit}
  .cal-day.empty{pointer-events:none}
  .cal-day.past{color:rgba(58,53,48,0.25);pointer-events:none}
  .cal-day.avail{cursor:pointer;font-weight:500}
  .cal-day.avail:hover{background:#DDE9F4;color:#1A4F7A}
  .cal-day.sel{background:#1A4F7A !important;color:#fff !important;font-weight:600}
  .time-slots-wrap{display:none}
  .time-slots-wrap.show{display:block}
  .time-slots-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px}
  .time-slots{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:16px}
  .time-slot{font-size:12px;padding:7px 12px;border-radius:8px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .time-slot:hover:not(.off){border-color:#1A4F7A;color:#1A4F7A}
  .time-slot.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .time-slot.off{color:rgba(58,53,48,0.3);border-color:rgba(58,53,48,0.1);background:transparent;cursor:not-allowed;text-decoration:line-through}
  .visit-input-group{margin-bottom:13px}
  .visit-input-label{font-size:11px;font-weight:500;color:#6B6560;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:5px}
  .visit-input{width:100%;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:8px;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;transition:border-color 0.15s}
  .visit-input:focus{border-color:#1A4F7A}
  .visit-phone-row{display:flex;gap:0}
  .visit-phone-flag{padding:10px 12px;border:0.5px solid rgba(58,53,48,0.22);border-right:none;border-radius:8px 0 0 8px;font-size:13px;background:#F8F6F2;color:#3A3530;cursor:default;white-space:nowrap}
  .visit-phone-input{flex:1;padding:10px 14px;border:0.5px solid rgba(58,53,48,0.22);border-radius:0 8px 8px 0;font-size:13px;color:#3A3530;font-family:inherit;outline:none;background:#F8F6F2;transition:border-color 0.15s}
  .visit-phone-input:focus{border-color:#1A4F7A}
  .investor-pills{display:flex;flex-wrap:wrap;gap:7px}
  .investor-pill{font-size:12px;padding:7px 13px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .investor-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .investor-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .budget-pills{display:flex;flex-wrap:wrap;gap:7px}
  .budget-pill{font-size:12px;padding:7px 13px;border-radius:999px;border:0.5px solid rgba(58,53,48,0.22);cursor:pointer;color:#6B6560;background:#F8F6F2;transition:all 0.15s;font-family:inherit}
  .budget-pill:hover{border-color:#1A4F7A;color:#1A4F7A}
  .budget-pill.sel{background:#1A4F7A;color:#fff;border-color:#1A4F7A}
  .visit-privacy{font-size:10px;color:#888078;line-height:1.6;margin-top:14px;margin-bottom:16px}
  .visit-privacy a{color:#1A4F7A;text-decoration:none}
  .visit-cta{width:100%;padding:13px;background:#1A4F7A;color:#fff;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:background 0.15s;font-family:inherit;letter-spacing:0.02em}
  .visit-cta:hover:not(:disabled){background:#0D2B44}
  .visit-cta:disabled{background:rgba(58,53,48,0.2);color:rgba(58,53,48,0.4);cursor:not-allowed}
  .visit-back{background:transparent;border:none;color:#6B6560;font-size:13px;cursor:pointer;padding:10px 0;font-family:inherit;display:inline-flex;align-items:center;gap:4px;margin-top:8px;transition:color 0.15s}
  .visit-back:hover{color:#3A3530}
  .confirm-box{background:#DDE9F4;border-radius:12px;padding:16px;margin-bottom:18px}
  .confirm-box-title{font-size:11px;font-weight:600;color:#0D2B44;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:10px}
  .confirm-row{display:flex;align-items:center;gap:8px;font-size:13px;color:#1A4F7A;margin-bottom:6px}
  .confirm-row:last-child{margin-bottom:0}
  .confirm-icon{font-size:14px;flex-shrink:0}
  .next-steps{margin-bottom:18px}
  .next-steps-title{font-size:12px;font-weight:600;color:#3A3530;margin-bottom:10px}
  .next-step-item{display:flex;align-items:flex-start;gap:10px;font-size:12px;color:#6B6560;margin-bottom:8px;line-height:1.5}
  .next-step-num{width:20px;height:20px;border-radius:50%;background:#DDE9F4;color:#1A4F7A;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
  .visit-outline-btn{width:100%;padding:11px;background:transparent;border:0.5px solid #1A4F7A;border-radius:10px;font-size:13px;font-weight:500;color:#1A4F7A;cursor:pointer;font-family:inherit;transition:all 0.15s;margin-bottom:10px;display:block;text-align:center;text-decoration:none}
  .visit-outline-btn:hover{background:#DDE9F4}
  .visit-dismiss-link{display:block;text-align:center;font-size:12px;color:#888078;cursor:pointer;margin-top:4px;transition:color 0.15s}
  .visit-dismiss-link:hover{color:#3A3530}

  /* ── Footer bottom bar ── */
  .footer-bar{background:var(--color-background-secondary);border-top:0.5px solid var(--color-border-tertiary);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
  .footer-bar-links{display:flex;gap:20px;flex-wrap:wrap}
  .footer-bar-links span{font-size:11px;color:var(--color-text-secondary);cursor:pointer}
  .footer-bar-links span:hover{color:var(--color-text-primary)}
  .footer-bar-copy{font-size:11px;color:var(--color-text-tertiary)}

  /* ── Responsive ── */
  @media(max-width:900px){
    .selector-grid{grid-template-columns:1fr 1fr}
    .cta-row{grid-template-columns:1fr 1fr}
  }
  @media(max-width:600px){
    .selector-grid{grid-template-columns:1fr}
    .cta-row{grid-template-columns:1fr}
    .page-title{font-size:24px}
    .page-inner{padding:28px 16px 60px}
    .compare-table-wrap{border-radius:var(--border-radius-md)}
    .visit-box{flex-direction:column;max-height:95vh;border-radius:16px 16px 0 0;position:fixed;bottom:0;left:0;right:0;width:100%;margin:0}
    .visit-left{display:none}
    .visit-right{padding:24px 20px 20px}
    .visit-modal{align-items:flex-end}
    .footer-bar{flex-direction:column;align-items:flex-start}
  }
---

<!-- Main content -->
<div class="page-inner">

  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/">Inicio</a>
    <span class="breadcrumb-sep">›</span>
    <span>Comparar proyectos</span>
  </div>

  <!-- Page header -->
  <div class="page-header">
    <h1 class="page-title">Comparar proyectos</h1>
    <p class="page-sub">Selecciona hasta 3 proyectos para ver sus métricas lado a lado</p>
  </div>

  <!-- Project selectors -->
  <div class="selector-grid">
    <div class="selector-col">
      <div class="selector-num">Proyecto 1</div>
      <div class="selector-label">Selecciona un proyecto</div>
      <select class="selector-select" id="sel0" onchange="onSelectChange(0)">
        <option value="">— Seleccionar proyecto —</option>
        <option value="kashi">Kashi Santa Marta ($320M · Santa Marta)</option>
        <option value="alma">Alma Luxury Lofts ($680M · Medellín)</option>
        <option value="parque93">Parque 93 Residences ($540M · Bogotá)</option>
        <option value="laureles">Laureles 60 ($380M · Medellín)</option>
        <option value="sanfernando">San Fernando Lofts ($720M · Cali)</option>
        <option value="kaali">Torre Kaali Cartagena ($480M · Cartagena)</option>
      </select>
    </div>
    <div class="selector-col">
      <div class="selector-num">Proyecto 2</div>
      <div class="selector-label">Selecciona un proyecto</div>
      <select class="selector-select" id="sel1" onchange="onSelectChange(1)">
        <option value="">— Seleccionar proyecto —</option>
        <option value="kashi">Kashi Santa Marta ($320M · Santa Marta)</option>
        <option value="alma">Alma Luxury Lofts ($680M · Medellín)</option>
        <option value="parque93">Parque 93 Residences ($540M · Bogotá)</option>
        <option value="laureles">Laureles 60 ($380M · Medellín)</option>
        <option value="sanfernando">San Fernando Lofts ($720M · Cali)</option>
        <option value="kaali">Torre Kaali Cartagena ($480M · Cartagena)</option>
      </select>
    </div>
    <div class="selector-col">
      <div class="selector-num">Proyecto 3 <span style="font-size:10px;color:#888078">(opcional)</span></div>
      <div class="selector-label">Selecciona un proyecto</div>
      <select class="selector-select" id="sel2" onchange="onSelectChange(2)">
        <option value="">— Seleccionar proyecto —</option>
        <option value="kashi">Kashi Santa Marta ($320M · Santa Marta)</option>
        <option value="alma">Alma Luxury Lofts ($680M · Medellín)</option>
        <option value="parque93">Parque 93 Residences ($540M · Bogotá)</option>
        <option value="laureles">Laureles 60 ($380M · Medellín)</option>
        <option value="sanfernando">San Fernando Lofts ($720M · Cali)</option>
        <option value="kaali">Torre Kaali Cartagena ($480M · Cartagena)</option>
      </select>
    </div>
  </div>

  <!-- Empty state -->
  <div id="emptyState">
    <svg class="empty-svg" width="120" height="90" viewBox="0 0 120 90" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Building left -->
      <rect x="8" y="28" width="44" height="58" rx="2" fill="#DDE9F4" stroke="#A8C4DC" stroke-width="1.5"/>
      <rect x="16" y="38" width="10" height="10" rx="1" fill="#5A8CB5" opacity="0.6"/>
      <rect x="32" y="38" width="10" height="10" rx="1" fill="#5A8CB5" opacity="0.6"/>
      <rect x="16" y="54" width="10" height="10" rx="1" fill="#5A8CB5" opacity="0.6"/>
      <rect x="32" y="54" width="10" height="10" rx="1" fill="#5A8CB5" opacity="0.6"/>
      <rect x="20" y="68" width="16" height="18" rx="1" fill="#A8C4DC"/>
