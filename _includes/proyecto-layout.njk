<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title if title else (p.nombre + " — Zonum") }}</title>
<meta name="description" content="{{ p.descripcion }}">
<meta property="og:title" content="{{ p.nombre }} — Proyecto curado por Zonum">
<meta property="og:description" content="{{ p.descripcion }}">
<meta property="og:image" content="{{ p.og_image }}">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
<link rel="stylesheet" href="https://use.typekit.net/bnk2dxj.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;min-height:100vh}
:root{
  /* ── Sistema Zonum base ── */
  --concreto-oscuro:#3A3530;--concreto-medio:#6B6560;--piedra:#888078;
  --blanco-calido:#F8F6F2;--lino:#F2EEE6;
  --oro-oscuro:#7A5C1E;--oro-acento:#B8975A;--champagne:#F2E8D0;
  --oro-palido:#D4AA6A;--ebano:#161210;
  --dark:#3A3530;--gold:#B8975A;
  --t1:#3A3530;--t2:#6B6560;--t3:#888078;
  --b1:rgba(58,53,48,0.12);--b2:rgba(58,53,48,0.22);
  --r8:8px;--r12:12px;--r16:16px;
  --color-background-primary:#F8F6F2;
  --color-background-secondary:#F2EEE6;
  --color-text-primary:#3A3530;
  --color-text-secondary:#6B6560;
  --color-text-tertiary:#888078;
  --color-border-tertiary:rgba(58,53,48,0.12);
  --color-border-secondary:rgba(58,53,48,0.22);
  --font-heading:'clother',sans-serif;

  /* ── Brand variables (override por proyecto) ── */
  --brand-primary: {{ p.brand.primary }};
  --brand-dark: {{ p.brand.primary_dark }};
  --brand-light: {{ p.brand.primary_light }};
  --brand-accent: {{ p.brand.accent }};
  --brand-accent-light: {{ p.brand.accent_light }};
  --brand-bg: {{ p.brand.bg }};
  --brand-card: {{ p.brand.bg_card }};
  --brand-invest-bg: {{ p.brand.invest_bg }};
  --brand-invest-text: {{ p.brand.invest_text }};
  --brand-invest-sub: {{ p.brand.invest_sub }};
}
body{background:var(--brand-bg)}
.wrap{max-width:1200px;margin:0 auto;padding:0 20px 40px}
</style>
</head>
<body>

{% include "nav.njk" %}

{{ content | safe }}

{% include "footer.njk" %}
{% include "whatsapp-fab.njk" %}
{% include "cookie-banner.njk" %}

<script>
function openVisitModal(proyecto, ciudad) {
  var msg = encodeURIComponent('Hola, quiero agendar una visita para ' + (proyecto || '{{ p.nombre }}') + (ciudad ? ' en ' + ciudad : ' en {{ p.ciudad }}'));
  window.open('https://wa.me/{{ p.whatsapp }}?text=' + msg, '_blank');
}
</script>

</body>
</html>
