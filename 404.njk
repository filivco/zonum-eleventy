          <path d="M5 28L17 8l12 20H5z" stroke="#1A4F7A" stroke-width="2" stroke-linejoin="round"/>
          <path d="M17 15v6M17 23.5v1" stroke="#1A4F7A" stroke-width="2" stroke-linecap="round"/>
